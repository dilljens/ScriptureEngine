# Scripture Engine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# LLM API key for chat features
export DEEPSEEK_API_KEY="sk-your-key-here"

# ntfy.sh push notifications (optional)
# Leave unset to disable push alerts on health failure
export NTFY_TOPIC=""
export NTFY_SERVER="https://ntfy.sh"

# CORS allowed origins (comma-separated)
# Frontend dev servers that can call this API
export CORS_ORIGINS="http://localhost:5173,http://localhost:5176,http://localhost:3000"

# Database path (optional — defaults to data/processed/scripture.db)
export SCRIPTURE_DB_PATH=""

# Server port
export PORT="8002"
